       bool "Ues strip LEDs"
       default n
       select STRIP_LED
       help
		Use strip LEDS


# Ready LED configuration
config USE_READY_LED
       bool "Enable the ready LED"
       default n
       select LED
       help
         The ready LED is mostly used for signalling on a microprosessor that does not have a console

choice READY_LED_TYPE
    prompt "Select Ready LED type"
    depends on USE_READY_LED
    default USE_READY_LED_GPIO

    config USE_READY_LED_GPIO
       bool "Enable a GPIO ready LED"
       help
          "Select if the ready LED is a GPIO LED"

    config USE_READY_LED_PWM
       select PWM
       bool "Enable a pwm ready LED"
       help
         Select if the ready led is a PWM led

    config USE_READY_LED_STRIP
       bool "Enable a led strip ready LED"
       select LED_STRIP
       help
        select if the ready led is a led strip

    config USE_READY_LED_CONTROLLER
       bool "Enable a LED Controller ready LED"
       help
         select if the ready led is controlled by a LED controller

    config USE_READY_LED_PICO_W
       bool "Enable the Pico W onboard LED"
       help
         select to use the onboard led on the Rasperry Pi Pico W

endchoice

config READY_LED_STACK_SIZE
    int "Size of the ready led stack"
    default 512 if BOARD_ESP32C6_DEVKITC
    default 336
    depends on USE_READY_LED
    help
        set the stack size for the ready led

