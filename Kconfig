# Seven Segment Display Configuration
config USE_SEVEN_SEGMENT_DISPLAY
       bool "Use seven segment display"
       default n
       help
	Enable the seven segment display

config USE_FOUR_ELEMENT_SEVEN_SEGMENT_DISPLAY
       bool "Use a 4 element 7 segment display"
       default n
       depends on USE_SEVEN_SEGMENT_DISPLAY

config USE_KY40
       bool "Use a KY40 dial"
       default n
       help
         The KY40 is a button/dial combo sensor

if USE_KY40

    configdefault INPUT
        default y

    configdefault INPUT_THREAD_STACK_SIZE
        default 2048

    configdefault INPUT_GPIO_QDEC
        default y
endif

config USE_LOWPOWER
    bool "Use power management"
    default n
    help
        "Enable power management support"

if USE_LOWPOWER
    configdefault PM
        default y
    configdefault PM_DEVICE
        default y
endif

config HAS_ESP_SLEEP
    bool "use esp32 speep function"
    default n

config USE_METEOROLOGY_SENSORS
