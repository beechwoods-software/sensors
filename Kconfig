# Analog to Digital convert configuration
config USE_ADC
       bool "configure adc gpio ports"
       default n
       select ADC
       help
        Enable the adc gpio ports

config USE_ADC_DEBOUNCE
      bool "Enable debounce of ADC"
      default n
      help
        Continiously sample the ADC. This is incomaptible with low power operation.
      depends on USE_ADC

config ADC_DEBOUNCE_STACK_SIZE
    int "Size of the ADC debounce stack"
    default 1024 if BOARD_ESP32S3_DEVKITC
    default 512
    depends on USE_ADC_DEBOUNCE
    help
        Size of the adc debounce stack -  per adc device

# The debounce uses a ring buffer of ADC_DEBONCE_SAMPLE_SIZE and samples every ADC_DEBOUNCE_CADENCE ms

config ADC_DEBOUNCE_SAMPLE_SIZE
    int "Number of samples in the ring buffer"
    depends on USE_ADC_DEBOUNCE
    default 100
    help
        This is the number of samples in the ring buffer

config ADC_DEBOUNCE_CADENCE
    int "Sleep time between samles (ms)"
    default 1000
    depends on USE_ADC_DEBOUNCE
    help
        The intervale between samples in ms.


# Button Configuration
config USE_BUTTON
       bool "Use button for changing type of display"
       default n
       help
         Use Button for input on changing type of display

# GPIO LED Configuratino
config USE_GPIO_LED
       bool "Use GPIO LEDS"
       default n
       help
         Enable the use of GPIO LEDs

# Motion Sensor configuration
config USE_MOTION_SENSOR
       bool "Use the motion sensor"
       default n
       help
         Configure a motion sensor for your project

config USE_MOTION_SENSOR_DEBOUNCE
      bool "Enable debounce of motion sensor"
      default n
      help
        supress motion callbacks for a periiod


config USE_MOTION_SENSOR_DEBOUNCE_DELAY
    int "number of milliseconds to supress callback"
    depends on USE_MOTION_SENSOR_DEBOUNCE
    default 5000
    help
        This is the number of milliseconds to supress user callback.


